print(names(Dados))

# Modelo One-step Limpo

Dados1<-Dados

#,MODELAGEM DE PAINEL DINÂMICO (GMM-DIF)

# 2. Modelo 1: One-Step (Estimativa em um passo)
# Útil para conferência inicial, mas menos robusto que o Two-Step.
Arelanoa<- pdynmc(
  dat              = Dados1, 
  varname.i        = "Países", 
  varname.t        = "Ano",
  use.mc.diff      = TRUE, 
  use.mc.lev       = FALSE, 
  use.mc.nonlin    = FALSE,
  include.y        = TRUE, 
  varname.y        = "ln_pibc", 
  lagTerms.y       = 1,
  maxLags.y        = 2,           
  fur.con          = TRUE, 
  fur.con.diff     = TRUE, 
  fur.con.lev      = FALSE,
  varname.reg.fur  = c("ln_com", "ln_inv", "Inflação", "Taxa.de.Câmbio", "Capital.Humano"),
  lagTerms.reg.fur = c(1, 1, 1, 1, 1),
  include.dum      = TRUE, 
  dum.diff         = TRUE, 
  dum.lev          = TRUE, 
  varname.dum      = "Ano",
  w.mat            = "iid.err", 
  std.err          = "corrected",
  estimation       = "onestep", 
  opt.meth         = "none"
)
summary(Arelanoa)

#  Modelo 2: Two-Step (Estimativa em dois passos - O MELHOR)
# Este modelo usa a matriz de pesos ótima e passou melhor no Teste J (Hansen).
Arelanoa_TwoStep <- pdynmc(
  dat              = Dados1, 
  varname.i        = "Países", 
  varname.t        = "Ano",
  use.mc.diff      = TRUE, 
  use.mc.lev       = FALSE, 
  use.mc.nonlin    = FALSE,      
  include.y        = TRUE, 
  varname.y        = "ln_pibc", 
  lagTerms.y       = 1,
  maxLags.y        = 2,           
  fur.con          = TRUE, 
  fur.con.diff     = TRUE, 
  fur.con.lev      = FALSE,      
  varname.reg.fur  = c("ln_com", "ln_inv", "Inflação", "Taxa.de.Câmbio", "Capital.Humano"),
  lagTerms.reg.fur = c(1, 1, 1, 1, 1),
  include.dum      = TRUE, 
  dum.diff         = TRUE, 
  dum.lev          = TRUE, 
  varname.dum      = "Ano",
  w.mat            = "iid.err", 
  std.err          = "corrected",
  estimation       = "twostep", 
  opt.meth         = "none"
)

summary(Arelanoa_TwoStep)

# --- MODELO GMM SISTÊMICO (SYSTEM GMM) ---

Arelanoa_System <- pdynmc(
  dat              = Dados1, 
  varname.i        = "Países", 
  varname.t        = "Ano",
  
  use.mc.diff      = TRUE, 
  use.mc.lev       = TRUE, 
  use.mc.nonlin    = FALSE,
  
  include.y        = TRUE, 
  varname.y        = "ln_pibc", 
  lagTerms.y       = 1,
  maxLags.y        = 2,           # REDUZIDO: Use apenas o lag 1 como instrumento
  
  fur.con          = TRUE, 
  fur.con.diff     = TRUE, 
  fur.con.lev      = FALSE,          # ALTERADO: Desativa instrumentos em nível para os controles
  
  varname.reg.fur  = c("ln_com", "ln_inv", "Inflação", "Taxa.de.Câmbio", "Capital.Humano"),
  lagTerms.reg.fur = c(1, 1, 1, 1, 1),
  
  include.dum      = TRUE, 
  dum.diff         = TRUE, 
  dum.lev          = FALSE,          # REDUZIDO: Menos dummies em nível para poupar graus de liberdade
  
  varname.dum      = "Ano",
  w.mat            = "iid.err", 
  std.err          = "corrected",
  estimation       = "twostep",  
  opt.meth         = "none"
)

summary(Arelanoa_System)

#TESTANDO A AUTOCORRELAÇÃO
# mtest.fct(Arelanob, t.order = 1)
# mtest.fct(Arelanob, t.order = 2)
# mtest.fct(Arelanob, t.order = 3)
#TESTE PARA RESTRIÇÕES DE SOBREIDENTIFICAÇÃO
jtest.fct(Arelanoa_System)
#TESTE DE SIGNIFICÂNCIA CONJUNTA DE TODOS OS PARÂMETROS
wald.fct(param = "all", object = Arelanoa_System)

#Autocorrelação
mtest.fct(Arelanoa_System)
##################################################################################
Arelano_Iterativo_Ajustado <- pdynmc(
  dat              = Dados1, 
  varname.i        = "Países", 
  varname.t        = "Ano",
  
  use.mc.diff      = TRUE, 
  use.mc.lev       = TRUE, 
  use.mc.nonlin    = FALSE,
  
  include.y        = TRUE, 
  varname.y        = "ln_pibc", 
  lagTerms.y       = 1,
  # LIMITANDO INSTRUMENTOS: Usa apenas os lags 2 e 3 como instrumentos
  maxLags.y        = 2,           
  
  fur.con          = TRUE, 
  fur.con.diff     = TRUE, 
  # Desativamos instrumentos em nível para os controles para evitar o Hansen = 1
  fur.con.lev      = FALSE,       
  
  varname.reg.fur  = c("ln_com", "ln_inv", "Inflação", "Taxa.de.Câmbio", "Capital.Humano"),
  lagTerms.reg.fur = c(0, 0, 0, 0, 0), 
  
  include.dum      = TRUE, 
  dum.diff         = TRUE, 
  dum.lev          = FALSE, # Dummies apenas em diferença para poupar o modelo
  varname.dum      = "Ano",
  
  w.mat            = "iid.err", 
  std.err          = "corrected", 
  estimation       = "iterative", # Mantemos o seu desejo pelo iterativo
  max.iter         = 50,          # 50 iterações costumam ser suficientes para convergir
  iter.tol         = 0.01, 
  opt.meth         = "none"
)

summary(Arelano_Iterativo_Ajustado)

