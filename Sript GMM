##################################################################################
# Analisar Série estacionária
# Estruturar o painel com os mesmos índices do seu pdynmc
painel_ips <- pdata.frame(Dados1,
                          index = c("Países", "Ano"),
                          drop.index = FALSE)

# Variável dependente
ips_pibc <- purtest(painel_ips$ln_pibc,
                    test = "ips", exo = "trend",
                    lags = "AIC", pmax = 4)
summary(ips_pibc)

# Corrente de comércio
ips_com <- purtest(painel_ips$ln_com,
                   test = "ips", exo = "trend",
                   lags = "AIC", pmax = 4)
summary(ips_com)

# Investimento (formação bruta de capital)
ips_inv <- purtest(painel_ips$ln_inv,
                   test = "ips", exo = "trend",
                   lags = "AIC", pmax = 4)
summary (ips_inv)

# Inflação (sem tendência — série oscilante por natureza)
ips_infla <- purtest(painel_ips$Inflação,
                     test = "ips", exo = "intercept",
                     lags = "AIC", pmax = 4)
summary(ips_infla)

# Taxa de câmbio
ips_cambio <- purtest(painel_ips$Taxa.de.Câmbio,
                      test = "ips", exo = "trend",
                      lags = "AIC", pmax = 4)
summary(ips_cambio)

# Capital humano
ips_hci <- purtest(painel_ips$Capital.Humano,
                   test = "ips", exo = "trend",
                   lags = "AIC", pmax = 4)
summary(ips_hci)

